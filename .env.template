# Vrihud Hastrekha - Environment Variables Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to git - add to .gitignore

# ============================================================================
# ESSENTIAL (Required to start)
# ============================================================================

# Anthropic API Key - Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-actual-api-key-here

# Database connection string
# For development: sqlite:///./palmistry.db
# For production: postgresql://user:password@host:5432/palmistry
DATABASE_URL=sqlite:///./palmistry.db

# Secret key for JWT tokens (generate random string minimum 32 characters)
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-random-secret-key-minimum-32-chars-change-this

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
LOG_LEVEL=info

# Environment (development, staging, production)
ENVIRONMENT=development

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600

# Enable database echo (SQL logging) - set to false in production
DB_ECHO=false

# ============================================================================
# AUTHENTICATION
# ============================================================================

# JWT token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Refresh token expiration (days)
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================================
# IMAGE PROCESSING
# ============================================================================

# Image limits
MAX_IMAGE_SIZE=10485760
IMAGE_QUALITY_JPEG=95

# ============================================================================
# SUBSCRIPTION CONFIGURATION
# ============================================================================

# Monthly reading limits per tier
FREE_TIER_MONTHLY_LIMIT=5
BASIC_TIER_MONTHLY_LIMIT=50

# API rate limits (requests per minute)
API_RATE_LIMIT_DEFAULT=60

# ============================================================================
# STRIPE (Payment Processing - Optional)
# ============================================================================

# Stripe API Keys - Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your-secret-key-here
STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key-here

# Enable/disable payments
ENABLE_PAYMENTS=false

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Sentry (Error tracking) - Get from https://sentry.io
SENTRY_DSN=

# Enable structured logging
ENABLE_JSON_LOGGING=false

# ============================================================================
# SECURITY & HEADERS
# ============================================================================

# HTTPS enforcement
ENFORCE_HTTPS=false

# Security headers
ENABLE_SECURITY_HEADERS=true

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Reload on code changes (development only)
RELOAD_ON_CHANGE=true

# Debug mode
DEBUG=true

# ============================================================================
# NOTES
# ============================================================================

# 1. Generate a strong SECRET_KEY:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 2. For Anthropic API key:
#    - Go to https://console.anthropic.com
#    - Create API key
#    - Copy here (starts with sk-ant-)
#
# 3. Add to .gitignore:
#    .env
#    .env.local
#    __pycache__/
#    *.pyc